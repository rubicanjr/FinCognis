Output assets/gif4-hooks.gif

Set Shell "bash"
Set FontSize 15
Set Width 620
Set Height 450
Set Theme { "name": "vibecosystem", "background": "#1a1b26", "foreground": "#c0caf5", "cursor": "#c0caf5", "selection": "#33467c", "black": "#15161e", "red": "#f7768e", "green": "#9ece6a", "yellow": "#e0af68", "blue": "#7aa2f7", "magenta": "#bb9af7", "cyan": "#7dcfff", "white": "#a9b1d6", "brightBlack": "#414868", "brightRed": "#f7768e", "brightGreen": "#9ece6a", "brightYellow": "#e0af68", "brightBlue": "#7aa2f7", "brightMagenta": "#bb9af7", "brightCyan": "#7dcfff", "brightWhite": "#c0caf5" }
Set Padding 20
Set TypingSpeed 40ms

Type "bash /tmp/vibe-gifs/hooks.sh"
Enter
Sleep 8s
