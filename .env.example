# LLM Providers (set the one you use)
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=
XAI_API_KEY=
DEEPSEEK_API_KEY=
DASHSCOPE_API_KEY=
ZHIPU_API_KEY=
OPENROUTER_API_KEY=

# TCMB EVDS API Key (ücretsiz)
# https://evds2.tcmb.gov.tr adresinden alın
TCMB_EVDS_API_KEY=

# Varsayılan LLM provider
LLM_PROVIDER=anthropic

# Varsayılan BIST evreni
BIST_UNIVERSE=bist30

# Tarama sonuçları kayıt dizini
SCREENING_OUTPUT_DIR=./screening_reports
