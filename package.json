{
  "name": "fincognis",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0",
    "start:local": "npm run build && npm run start -- -p 4173",
    "start:windows": "powershell -ExecutionPolicy Bypass -File scripts/start-local.ps1 -Port 4173",
    "start:windows:fast": "powershell -ExecutionPolicy Bypass -File scripts/start-local.ps1 -Port 4173 -SkipBuild",
    "start:windows:keepalive": "powershell -ExecutionPolicy Bypass -File scripts/start-local-keepalive.ps1 -Port 4173",
    "lint": "next lint",
    "test": "vitest run",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.13",
    "@supabase/supabase-js": "^2.57.4",
    "autoprefixer": "^10.4.20",
    "lucide-react": "^0.542.0",
    "next": "^14.2.18",
    "postcss": "^8.4.49",
    "puppeteer": "^24.42.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.1",
    "tailwindcss": "^3.4.17",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "22.19.17",
    "@types/react": "18.3.28",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^27.0.0",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
