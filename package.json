{
  "name": "fincognis",
  "private": true,
  "version": "2.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start --hostname 0.0.0.0 --port 4173",
    "start:local": "npm run build && npm run start",
    "start:windows": "powershell -ExecutionPolicy Bypass -File scripts/start-local.ps1 -Port 4173",
    "start:windows:rebuild": "powershell -ExecutionPolicy Bypass -File scripts/start-local.ps1 -Port 4173 -Rebuild",
    "start:windows:keepalive": "powershell -ExecutionPolicy Bypass -File scripts/start-local-keepalive.ps1 -Port 4173",
    "lint": "next lint",
    "test": "vitest run"
  },
  "dependencies": {
    "@radix-ui/react-tabs": "^1.1.13",
    "autoprefixer": "^10.4.20",
    "lucide-react": "^0.542.0",
    "next": "^14.2.18",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@supabase/supabase-js": "^2.57.4",
    "tailwindcss": "^3.4.17",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/node": "22.19.17",
    "@types/react": "18.3.28",
    "@types/react-dom": "^18.3.5",
    "jsdom": "^27.0.0",
    "typescript": "5.9.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=18"
  }
}
